{
  "name": "@butlerov-chemistry/core",
  "version": "0.1.4",
  "description": "Draw chemical structures with js and Konva",
  "type": "module",
  "main": "./dist/butlerov.umd.cjs",
  "module": "./dist/butlerov.es.cjs",
  "types": "./dist/main.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/main.d.ts",
        "default": "./dist/butlerov.es.cjs"
      },
      "require": {
        "types": "./dist/main.d.ts",
        "default": "./dist/butlerov.umd.cjs"
      }
    }
  },
  "build": {
    "appId": "com.lumiprobe.butlerov.app"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "clean": "rimraf -g dist",
    "lint": "eslint",
    "pretest": "playwright install chromium",
    "test": "vitest run",
    "prepare": "npm run build"
  },
  "keywords": [
    "chemistry",
    "structure",
    "2d"
  ],
  "author": "Project team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eizemazal/butlerov.git",
    "directory": "packages/core"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin-js": "^2.13.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/user-event": "^14.6.1",
    "@vitest/browser-playwright": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "globals": "^15.15.0",
    "playwright": "^1.53.2",
    "vite-plugin-dts": "^4.5.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "konva": "^9.3.18"
  },
  "files": [
    "dist/**/*"
  ]
}
